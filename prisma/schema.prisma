generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Business {
  id           Int      @id @default(autoincrement())
  name         String
  category     String
  subcategory  String
  description  String
  address      String
  neighborhood String
  imageUrl     String
  rating       Float    @default(0)
  createdAt    DateTime @default(now())
  reviews      Review[]
}

model Review {
  id            Int      @id @default(autoincrement())
  businessId    Int
  rating        Int
  text          String
  nullifierHash String
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id])

  @@unique([nullifierHash, businessId])
}
